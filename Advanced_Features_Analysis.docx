// File: src/components/AuthImagePattern.jsx
const AuthImagePattern = ({ title, subtitle }) => {
  return (
    <div className="hidden lg:flex items-center justify-center bg-base-200 p-12">
      <div className="max-w-md text-center">
        <div className="grid grid-cols-3 gap-3 mb-8">
          {[...Array(9)].map((_, i) => (
            <div
              key={i}
              className={`aspect-square rounded-2xl bg-primary/10 ${
                i % 2 === 0 ? "animate-pulse" : ""
              }`}
            />
          ))}
        </div>
        <h2 className="text-2xl font-bold mb-4">{title}</h2>
        <p className="text-base-content/60">{subtitle}</p>
      </div>
    </div>
  );
};
```

**Learning Points:**
- **Array Spread**: `[...Array(9)]` for creating array of specific length
- **Conditional Animation**: `i % 2 === 0 ? "animate-pulse" : ""` for alternating effects
- **Responsive Visibility**: `hidden lg:flex` for desktop-only display
- **Props Pattern**: Flexible content through props
- **Grid Generation**: Programmatic grid item creation

