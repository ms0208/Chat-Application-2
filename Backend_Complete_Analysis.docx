## 4. Authentication System Implementation

### 4.1 JWT Token Generation Utility
**File: `lib/utils.js`**

Secure token generation with comprehensive security measures:

```javascript
import jwt from "jsonwebtoken";

export const generateToken = (userId, res) => {
  const JWT = process.env.JWT_SECRET;
  const token = jwt.sign({ userId }, JWT, {
    expiresIn: "7d",
  });

  res.cookie("jwt", token, {
    maxAge: 7 * 24 * 60 * 60 * 1000, // 7 days in milliseconds
    httpOnly: true,                   // Prevent XSS attacks
    sameSite: "strict",              // CSRF attack prevention
    secure: process.env.NODE_ENV !== "development",
  });

  return token;
};
```

**Security Implementation Analysis:**

**JWT Token Configuration:**
- `expiresIn: "7d"`: Token validity period (7 days)
- Payload contains only user ID (minimal data exposure)
- Secret key from environment variables (never hardcoded)

**Cookie Security Features:**
- `httpOnly: true`: Prevents JavaScript access to cookie (XSS protection)
- `sameSite: "strict"`: Blocks cross-site request forgery (CSRF)
- `secure`: HTTPS-only in production (man-in-the-middle protection)
- `maxAge`: Cookie expiration matching token expiration

**Security Best Practices:**
- Environment-based security configuration
- Minimal token payload to reduce exposure risk
- Multiple layers of security (HttpOnly + SameSite + Secure)

### 4.2 Authentication Middleware
**File: `middleware/auth.middleware.js`**

Request authentication and authorization system:

```javascript
import jwt from "jsonwebtoken";
import User from "../models/user.model.js";
import dotenv from 'dotenv';
dotenv.config();

export const protectRoute = async (req, res, next) => {
  try {
    const token = req.cookies.jwt;

    if (!token) {
      return res.status(401).json({ message: "Unauthorized - No Token Provided" });
    }

    const decoded = jwt.verify(token, process.env.JWT_SECRET);

    if (!decoded) {
      return res.status(401).json({ message: "Unauthorized - Invalid Token" });
    }

    const user = await User.findById(decoded.userId).select("-password");

    if (!user) {
      return res.status(404).json({ message: "User not found" });
    }

    req.user = user;
    next();
  } catch (error) {
    console.log("Error in protectRoute middleware: ", error.message);
    res.status(500).json({ message: "Internal server error" });
  }
};
```

**Middleware Concepts Explained:**

**Authentication Flow:**
1. Extract JWT token from HTTP cookies
2. Verify token signature and expiration
3. Decode user information from token payload
4. Fetch user data from database
5. Attach user object to request for downstream use

**Error Handling Strategy:**
- Different status codes for different error types
- 401: Unauthorized (no token, invalid token)
- 404: User not found (token valid but user deleted)
- 500: Server error (database issues, etc.)

**Security Considerations:**
- Password exclusion from user data (`.select("-password")`)
- Token verification against secret key
- User existence validation
- Comprehensive error logging

**Middleware Pattern:**
- `next()`: Passes control to next middleware/route handler
- `req.user`: Attaches authenticated user to request object
- Reusable across multiple protected routes

### 4.3 Authentication Controllers
**File: `controllers/auth.controller.js`**

Complete authentication system with registration, login, and profile management:

```javascript
import { generateToken } from "../lib/utils.js";
import User from "../models/user.model.js";
import bcrypt from "bcryptjs";
import cloudinary from "../lib/cloudinary.js";

export const signup = async (req, res) => {
  const { fullName, email, password } = req.body;
  try {
    // Input validation
    if (!fullName || !email || !password) {
      return res.status(400).json({ message: "All fields are required" });
    }

    if (password.length < 6) {
      return res.status(400).json({ message: "Password must be at least 6 characters" });
    }

    // Check for existing user
    const user = await User.findOne({ email });
    if (user) return res.status(400).json({ message: "Email already exists" });

    // Password hashing
    const salt = await bcrypt.genSalt(10);
    const hashedPassword = await bcrypt.hash(password, salt);

    // Create new user
    const newUser = new User({
      fullName,
      email,
      password: hashedPassword,
    });

    if (newUser) {
      generateToken(newUser._id, res);
      await newUser.save();

      res.status(201).json({
        _id: newUser._id,
        fullName: newUser.fullName,
        email: newUser.email,
        profilePic: newUser.profilePic,
      });
    } else {
      res.status(400).json({ message: "Invalid user data" });
    }
  } catch (error) {
    console.log("Error in signup controller", error.message);
    res.status(500).json({ message: "Internal Server Error" });
  }
};

export const login = async (req, res) => {
  const { email, password } = req.body;
  try {
    const user = await User.findOne({ email });

    if (!user) {
      return res.status(400).json({ message: "Invalid credentials" });
    }

    const isPasswordCorrect = await bcrypt.compare(password, user.password);
    if (!isPasswordCorrect) {
      return res.status(400).json({ message: "Invalid credentials" });
    }

    generateToken(user._id, res);

    res.status(200).json({
      _id: user._id,
      fullName: user.fullName,
      email: user.email,
      profilePic: user.profilePic,
    });
  } catch (error) {
    console.log("Error in login controller", error.message);
    res.status(500).json({ message: "Internal Server Error" });
  }
};

export const logout = (req, res) => {
  try {
    res.cookie("jwt", "", { maxAge: 0 });
    res.status(200).json({ message: "Logged out successfully" });
  } catch (error) {
    console.log("Error in logout controller", error.message);
    res.status(500).json({ message: "Internal Server Error" });
  }
};

export const updateProfile = async (req, res) => {
  try {
    const { profilePic } = req.body;
    const userId = req.user._id;

    if (!profilePic) {
      return res.status(400).json({ message: "Profile pic is required" });
    }

    const uploadResponse = await cloudinary.uploader.upload(profilePic);
    const updatedUser = await User.findByIdAndUpdate(
      userId,
      { profilePic: uploadResponse.secure_url },
      { new: true }
    );

    res.status(200).json(updatedUser);
  } catch (error) {
    console.log("error in update profile:", error);
    res.status(500).json({ message: "Internal server error" });
  }
};

export const checkAuth = (req, res) => {
  try {
    res.status(200).json(req.user);
  } catch (error) {
    console.log("Error in checkAuth controller", error.message);
    res.status(500).json({ message: "Internal Server Error" });
  }
};
```

**Controller Implementation Analysis:**

**Signup Process:**
1. Input validation (required fields, password length)
2. Duplicate email check
3. Password hashing with bcrypt salt
4. User creation and database storage
5. Automatic login with token generation
6. Secure response (password excluded)

**Password Security:**
- `bcrypt.genSalt(10)`: Generates cryptographic salt
- `bcrypt.hash()`: Creates irreversible password hash
- Salt rounds (10) balance security vs performance

**Login Process:**
1. User lookup by email
2. Password verification using bcrypt comparison
3. Token generation for authenticated session
4. User data response (excluding password)

**Logout Implementation:**
- Cookie invalidation by setting empty value
- Immediate expiration (`maxAge: 0`)
- Simple but effective session termination

**Profile Update Features:**
- Protected route (requires authentication)
- Cloudinary integration for image upload
- Database update with new profile picture URL
- Atomic update operation

**Authentication Check:**
- Middleware-dependent endpoint
- Returns current user data
- Used for session validation on frontend

